<nav class="sidebar sidebar-employee">
    <div class="sidebar-logo">
        <div class="logo-icon logo-icon-employee">AB</div>
        <div>
            <div class="logo-text">American Bank</div>
            <div class="logo-sub">Employee Portal</div>
        </div>
    </div>

    <div class="sidebar-nav">
        <div class="nav-section-label">Overview</div>
        <NavLink class="nav-link" href="employee/dashboard" Match="NavLinkMatch.All">
            Dashboard
        </NavLink>

        <div class="nav-section-label">Customers</div>
        <NavLink class="nav-link" href="employee/create-customer">
            Create Customer
        </NavLink>
        <NavLink class="nav-link" href="employee/customers">
            Customer List
        </NavLink>

        <div class="nav-section-label">Account</div>
        <NavLink class="nav-link" href="settings">
            Settings
        </NavLink>
    </div>

    <div class="sidebar-footer">
        <AuthorizeView>
            <Authorized>
                <div class="sidebar-user">
                    <div class="user-avatar user-avatar-employee">@GetInitials(context.User)</div>
                    <div class="user-info">
                        <div class="user-name">@GetName(context.User)</div>
                        <div class="user-email">@GetEmail(context.User)</div>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private string GetName(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value ?? "Employee";
        var lastName = user.FindFirst("lastName")?.Value ?? "";
        return $"{firstName} {lastName}".Trim();
    }

    private string GetEmail(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.FindFirst("email")?.Value ?? "employee@americanbank.com";
    }

    private string GetInitials(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value ?? "E";
        var lastName = user.FindFirst("lastName")?.Value ?? "M";
        
        string initials = "";
        if (!string.IsNullOrEmpty(firstName)) initials += firstName[0];
        if (!string.IsNullOrEmpty(lastName)) initials += lastName[0];
        
        return string.IsNullOrEmpty(initials) ? "AD" : initials.ToUpper();
    }
}
