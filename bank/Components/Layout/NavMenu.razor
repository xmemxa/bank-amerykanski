<nav class="sidebar">
    <div class="sidebar-logo">
        <div class="logo-icon">AB</div>
        <div>
            <div class="logo-text">American Bank</div>
            <div class="logo-sub">Online Banking</div>
        </div>
    </div>

    <div class="sidebar-nav">
        <div class="nav-section-label">Main</div>
        <NavLink class="nav-link" href="dashboard" Match="NavLinkMatch.All">
            Dashboard
        </NavLink>
        <NavLink class="nav-link" href="history">
            Transaction History
        </NavLink>

        <div class="nav-section-label">Transfers</div>
        <NavLink class="nav-link" href="transfer/internal">
            Internal Transfer
        </NavLink>
        <NavLink class="nav-link" href="transfer/ach">
            ACH Transfer
        </NavLink>
        <NavLink class="nav-link" href="transfer/fednow">
            FedNow Instant
        </NavLink>
        <NavLink class="nav-link" href="transfer/wire">
            Wire Transfer
        </NavLink>
        <NavLink class="nav-link" href="transfer/swift">
            SWIFT International
        </NavLink>

        <div class="nav-section-label">Account</div>
        <NavLink class="nav-link" href="settings">
            Settings
        </NavLink>
    </div>

    <div class="sidebar-footer">
        <AuthorizeView>
            <Authorized>
                <div class="sidebar-user">
                    <div class="user-avatar">@GetInitials(context.User)</div>
                    <div class="user-info">
                        <div class="user-name">@GetName(context.User)</div>
                        <div class="user-email">@GetEmail(context.User)</div>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private string GetName(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value ?? "Customer";
        var lastName = user.FindFirst("lastName")?.Value ?? "";
        return $"{firstName} {lastName}".Trim();
    }

    private string GetEmail(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.FindFirst("email")?.Value ?? "customer@email.com";
    }

    private string GetInitials(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value ?? "C";
        var lastName = user.FindFirst("lastName")?.Value ?? "S";
        
        string initials = "";
        if (!string.IsNullOrEmpty(firstName)) initials += firstName[0];
        if (!string.IsNullOrEmpty(lastName)) initials += lastName[0];
        
        return string.IsNullOrEmpty(initials) ? "US" : initials.ToUpper();
    }
}
