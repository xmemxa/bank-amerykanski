@page "/account/{AccountId}"
@rendermode InteractiveServer

<PageTitle>Account Details – American Bank</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>Primary Checking</h1>
        <p class="page-subtitle">Account details and transaction activity</p>
    </div>

    <!-- Account Info -->
    <div class="info-grid">
        <div class="info-item">
            <div class="info-label">Available Balance</div>
            <div class="info-value" style="font-size: 1.5rem;">$12,458.32</div>
        </div>
        <div class="info-item">
            <div class="info-label">Routing Number (ABA)</div>
            <div class="info-value mono">123456789</div>
        </div>
        <div class="info-item">
            <div class="info-label">Account Number</div>
            <div class="info-value mono">0012344521</div>
        </div>
        <div class="info-item">
            <div class="info-label">Account Type</div>
            <div class="info-value">Checking (Standard)</div>
        </div>
        <div class="info-item">
            <div class="info-label">Currency</div>
            <div class="info-value">USD – US Dollar</div>
        </div>
        <div class="info-item">
            <div class="info-label">Opened On</div>
            <div class="info-value">January 15, 2024</div>
        </div>
    </div>

    <!-- Actions -->
    <div class="quick-actions" style="margin-bottom: 1.5rem;">
        <a href="/transfer/internal" class="btn btn-primary">Transfer Funds</a>
        <a href="/transfer/ach" class="btn btn-secondary">Send ACH</a>
        <a href="/transfer/wire" class="btn btn-secondary">Wire Transfer</a>
    </div>

    <!-- Transactions for this account -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Account Activity</h3>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th style="text-align: right;">Amount</th>
                        <th style="text-align: right;">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>May 12, 2026</td>
                        <td>Payroll Deposit – Acme Corp</td>
                        <td><span class="badge badge-info">ACH</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-positive">+$3,450.00</td>
                        <td style="text-align: right;" class="amount">$12,458.32</td>
                    </tr>
                    <tr>
                        <td>May 11, 2026</td>
                        <td>Transfer to Savings</td>
                        <td><span class="badge badge-info">Internal</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-negative">−$500.00</td>
                        <td style="text-align: right;" class="amount">$9,008.32</td>
                    </tr>
                    <tr>
                        <td>May 10, 2026</td>
                        <td>Wire to ABC Realty</td>
                        <td><span class="badge badge-info">Wire</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-negative">−$2,100.00</td>
                        <td style="text-align: right;" class="amount">$9,508.32</td>
                    </tr>
                    <tr>
                        <td>May 9, 2026</td>
                        <td>FedNow from Jane Smith</td>
                        <td><span class="badge badge-info">FedNow</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-positive">+$250.00</td>
                        <td style="text-align: right;" class="amount">$11,608.32</td>
                    </tr>
                    <tr>
                        <td>May 8, 2026</td>
                        <td>SWIFT – London Office</td>
                        <td><span class="badge badge-info">SWIFT</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-negative">−$5,000.00</td>
                        <td style="text-align: right;" class="amount">$11,358.32</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? AccountId { get; set; }
}
