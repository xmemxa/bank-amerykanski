@page "/dashboard"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<PageTitle>Dashboard – American Bank</PageTitle>

<div class="fade-in">
    @if (isLoading)
    {
        <div style="text-align: center; padding: 2rem;">Loading your dashboard...</div>
    }
    else if (summary != null)
    {
        <div class="page-header">
            <h1>Good evening, @summary.FirstName</h1>
            <p class="page-subtitle">Here's your financial overview</p>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <a href="/transfer/internal" class="quick-action-btn">Transfer</a>
            <a href="/transfer/internal" class="quick-action-btn">Send Money</a>
            <a href="/transfer/internal" class="quick-action-btn">Instant Pay</a>
            <a href="/transfer/internal" class="quick-action-btn">International</a>
            <a href="/history" class="quick-action-btn">Statements</a>
        </div>

        <!-- Account Cards -->
        <h2 style="margin-bottom: 1rem;">Your Accounts</h2>
        <div class="accounts-grid">
            @foreach (var account in summary.Accounts)
            {
                <a href="/account/@account.Id" class="account-card" style="text-decoration: none;">
                    <div class="account-type">@account.AccountType Account</div>
                    <div class="account-name">Primary @account.AccountType</div>
                    <div class="account-balance">
                        <span class="currency">$</span>@account.Balance.ToString("N2")
                    </div>
                    <div class="account-number">Routing: @account.RoutingNumber &middot; Acct: &middot;&middot;&middot;&middot;@(account.AccountNumber.Length >= 4 ? account.AccountNumber.Substring(account.AccountNumber.Length - 4) : account.AccountNumber)</div>
                </a>
            }
            @if (!summary.Accounts.Any())
            {
                <div>No accounts found.</div>
            }
        </div>

        <!-- Recent Transactions -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Recent Transactions</h3>
                <a href="/history" class="btn btn-ghost">View All</a>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Description</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th style="text-align: right;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in summary.RecentTransactions)
                        {
                            <tr>
                                <td>@t.Timestamp.ToString("MMM dd, yyyy")</td>
                                <td>@t.Description</td>
                                <td><span class="badge badge-info">@t.TransactionType</span></td>
                                <td>
                                    @if (t.Status == "Completed")
                                    {
                                        <span class="badge badge-completed">Completed</span>
                                    }
                                    else if (t.Status == "Pending")
                                    {
                                        <span class="badge badge-pending">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-failed">@t.Status</span>
                                    }
                                </td>
                                <td style="text-align: right;" class="amount @(t.IsCredit ? "amount-positive" : "amount-negative")">
                                    @(t.IsCredit ? "+" : "−")$@t.Amount.ToString("N2")
                                </td>
                            </tr>
                        }
                        @if (!summary.RecentTransactions.Any())
                        {
                            <tr><td colspan="5" style="text-align: center;">No recent transactions.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div style="text-align: center; color: var(--error);">@errorMessage</div>
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private DashboardSummary? summary;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);
            
            var tokenResult = await SessionStorage.GetAsync<string>("authToken");
            if (tokenResult.Success && !string.IsNullOrEmpty(tokenResult.Value))
            {
                client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", tokenResult.Value);
            }
            else
            {
                errorMessage = "Authentication token missing. Please log in again.";
                isLoading = false;
                return;
            }
            
            var response = await client.GetAsync("api/account/summary");
            if (response.IsSuccessStatusCode)
            {
                summary = await response.Content.ReadFromJsonAsync<DashboardSummary>();
            }
            else
            {
                errorMessage = "Failed to load dashboard data.";
            }
        }
        catch (Exception)
        {
            errorMessage = "A network error occurred. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class DashboardSummary
    {
        public string FirstName { get; set; } = "";
        public List<AccountInfo> Accounts { get; set; } = new();
        public List<TransactionInfo> RecentTransactions { get; set; } = new();
    }

    public class AccountInfo
    {
        public Guid Id { get; set; }
        public string AccountType { get; set; } = "";
        public string AccountNumber { get; set; } = "";
        public string RoutingNumber { get; set; } = "";
        public decimal Balance { get; set; }
        public string Currency { get; set; } = "USD";
    }

    public class TransactionInfo
    {
        public Guid Id { get; set; }
        public DateTime Timestamp { get; set; }
        public string Description { get; set; } = "";
        public string TransactionType { get; set; } = "";
        public string Status { get; set; } = "";
        public decimal Amount { get; set; }
        public string Currency { get; set; } = "USD";
        public bool IsCredit { get; set; }
    }
}
