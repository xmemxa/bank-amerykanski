@page "/employee/create-customer"
@rendermode InteractiveServer
@inject bank.Services.AuthService AuthService

<PageTitle>Create Customer – American Bank Employee Portal</PageTitle>

<div class="fade-in transfer-page-center">
    <div class="page-header">
        <h1>Create New Customer</h1>
        <p class="page-subtitle">Register a new bank customer and open their first account</p>
    </div>

    <div class="card">
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>

            <!-- Show created account details -->
            <div class="info-grid" style="margin-bottom: 1.5rem;">
                <div class="info-item">
                    <div class="info-label">Customer User ID</div>
                    <div class="info-value mono">@model.Username</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Routing Number</div>
                    <div class="info-value mono">123456789</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Account Number</div>
                    <div class="info-value mono">@generatedAccountNumber</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Temporary Password</div>
                    <div class="info-value mono">@model.TemporaryPassword</div>
                </div>
            </div>

            <div class="alert alert-info">
                Please provide the above credentials to the customer. They should change their password upon first login.
            </div>

            <button class="btn btn-primary btn-full" style="margin-top: 1rem;" @onclick="ResetForm">Create Another Customer</button>
        }

        @if (string.IsNullOrEmpty(successMessage))
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-error">@errorMessage</div>
            }

            <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="CreateCustomerForm">
                <DataAnnotationsValidator />
                
                <h3 style="margin: 0 0 1rem; color: var(--text-secondary); font-size: 0.875rem;">Personal Information</h3>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">First Name</label>
                        <InputText class="form-input" @bind-Value="model.FirstName" placeholder="John" />
                        <ValidationMessage For="() => model.FirstName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Last Name</label>
                        <InputText class="form-input" @bind-Value="model.LastName" placeholder="Doe" />
                        <ValidationMessage For="() => model.LastName" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <InputText class="form-input" @bind-Value="model.Email" placeholder="john.doe@example.com" />
                    <ValidationMessage For="() => model.Email" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Social Security Number (SSN)</label>
                        <InputText class="form-input" @bind-Value="model.SocialSecurityNumber" placeholder="XXX-XX-XXXX" />
                        <ValidationMessage For="() => model.SocialSecurityNumber" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone Number</label>
                        <InputText class="form-input" @bind-Value="model.PhoneNumber" placeholder="(555) 123-4567" />
                        <ValidationMessage For="() => model.PhoneNumber" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Physical Address</label>
                    <InputText class="form-input" @bind-Value="model.Address" placeholder="123 Main St, City, State, ZIP" />
                    <ValidationMessage For="() => model.Address" />
                </div>

                <h3 style="margin: 1.5rem 0 1rem; color: var(--text-secondary); font-size: 0.875rem;">Account Setup</h3>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Login User ID</label>
                        <InputText class="form-input" @bind-Value="model.Username" placeholder="e.g., johndoe1" />
                        <ValidationMessage For="() => model.Username" />
                        <span class="form-hint">Used by customer to log in</span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Temporary Password</label>
                        <InputText class="form-input" @bind-Value="model.TemporaryPassword" placeholder="Minimum 8 characters" />
                        <ValidationMessage For="() => model.TemporaryPassword" />
                    </div>
                </div>

                <h3 style="margin: 1.5rem 0 1rem; color: var(--text-secondary); font-size: 0.875rem;">Account Details</h3>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Account Type</label>
                        <InputSelect class="form-select" @bind-Value="model.AccountType">
                            <option value="Checking">Checking Account</option>
                            <option value="Savings">Savings Account</option>
                        </InputSelect>
                        <ValidationMessage For="() => model.AccountType" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Currency</label>
                        <InputSelect class="form-select" @bind-Value="model.Currency">
                            <option value="USD">USD – US Dollar</option>
                        </InputSelect>
                        <ValidationMessage For="() => model.Currency" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Initial Deposit (USD)</label>
                    <InputNumber class="form-input" @bind-Value="model.InitialDeposit" placeholder="0.00" />
                    <ValidationMessage For="() => model.InitialDeposit" />
                    <span class="form-hint">Optional – amount the customer is depositing at account opening</span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg btn-full" style="margin-top: 1.5rem;" disabled="@isLoading">
                    @(isLoading ? "Creating..." : "Create Customer & Open Account")
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    private CreateCustomerModel model = new();
    private string? successMessage;
    private string? errorMessage;
    private string generatedAccountNumber = "";
    private bool isLoading = false;

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        var requestData = new
        {
            Username = model.Username,
            Email = model.Email,
            SocialSecurityNumber = model.SocialSecurityNumber,
            Address = model.Address,
            PhoneNumber = model.PhoneNumber,
            Password = model.TemporaryPassword,
            FirstName = model.FirstName,
            LastName = model.LastName,
            AccountType = model.AccountType,
            Currency = model.Currency,
            InitialDeposit = model.InitialDeposit
        };

        var result = await AuthService.RegisterAsync(requestData);

        if (result.Success)
        {
            generatedAccountNumber = result.AccountNumber ?? "Pending";
            successMessage = $"Customer {model.FirstName} {model.LastName} created successfully.";
        }
        else
        {
            errorMessage = result.ErrorMessage ?? "Failed to create customer.";
        }

        isLoading = false;
    }

    private void ResetForm()
    {
        model = new();
        successMessage = null;
        errorMessage = null;
        generatedAccountNumber = "";
    }

    public class CreateCustomerModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "First name is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(50, ErrorMessage = "First name cannot exceed 50 characters.")]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Last name is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(50, ErrorMessage = "Last name cannot exceed 50 characters.")]
        public string LastName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "User ID is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(20, MinimumLength = 4, ErrorMessage = "User ID must be between 4 and 20 characters.")]
        public string Username { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email address is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email address format.")]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "SSN is required.")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^\d{3}-\d{2}-\d{4}$", ErrorMessage = "SSN must be in format XXX-XX-XXXX.")]
        public string SocialSecurityNumber { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Phone number is required.")]
        [System.ComponentModel.DataAnnotations.Phone(ErrorMessage = "Invalid phone number format.")]
        public string PhoneNumber { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Physical address is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(200, ErrorMessage = "Address cannot exceed 200 characters.")]
        public string Address { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Temporary password is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 8, ErrorMessage = "Password must be at least 8 characters.")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$", ErrorMessage = "Password must contain at least one uppercase letter, one lowercase letter, one number, and one special character.")]
        public string TemporaryPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string AccountType { get; set; } = "Checking";

        [System.ComponentModel.DataAnnotations.Required]
        public string Currency { get; set; } = "USD";

        [System.ComponentModel.DataAnnotations.Range(0, 1000000000, ErrorMessage = "Initial deposit must be non-negative.")]
        public decimal InitialDeposit { get; set; }
    }
}
