@page "/employee/customers"
@rendermode InteractiveServer

<PageTitle>Customer List – American Bank Employee Portal</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>Customer List</h1>
        <p class="page-subtitle">Manage and search all bank customers</p>
    </div>

    <!-- Search Bar -->
    <div class="filter-bar">
        <div class="form-group" style="margin-bottom: 0; flex: 1; min-width: 250px;">
            <label class="form-label">Search</label>
            <InputText class="form-input" @bind-Value="searchQuery" placeholder="Search by name, SSN, or phone number..." style="max-width: 100%;" />
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Account Type</label>
            <select class="form-select" @bind="filterType">
                <option value="">All Types</option>
                <option value="Checking">Checking</option>
                <option value="Savings">Savings</option>
                <option value="Junior">Junior</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 0; display: flex; align-items: flex-end;">
            <button class="btn btn-primary" @onclick="ApplySearch">Search</button>
        </div>
    </div>

    <!-- Results -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Results (8 customers)</h3>
            <a href="/employee/create-customer" class="btn btn-primary">+ New Customer</a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Phone / SSN</th>
                        <th>Accounts</th>
                        <th>Total Balance</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
