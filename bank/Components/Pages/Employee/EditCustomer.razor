@page "/employee/customer/{Id}/edit"
@rendermode InteractiveServer

<PageTitle>Edit Customer – American Bank Employee Portal</PageTitle>

<div class="fade-in transfer-page-center">
    <div class="page-header">
        <h1>Edit Customer</h1>
        <p class="page-subtitle">Update information for John Doe</p>
    </div>

    <div class="card">
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="EditCustomerForm">
            <h3 style="margin: 0 0 1rem; color: var(--text-secondary); font-size: 0.875rem;">Personal Information</h3>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <InputText class="form-input" @bind-Value="model.FirstName" />
                </div>
                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <InputText class="form-input" @bind-Value="model.LastName" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Phone Number</label>
                    <InputText class="form-input" @bind-Value="model.PhoneNumber" />
                </div>
                <div class="form-group">
                    <label class="form-label">Physical Address</label>
                    <InputText class="form-input" @bind-Value="model.Address" />
                </div>
            </div>

            <h3 style="margin: 1.5rem 0 1rem; color: var(--text-secondary); font-size: 0.875rem;">Security</h3>

            <div class="form-group">
                <label class="form-label">Reset Password</label>
                <InputText class="form-input" @bind-Value="model.NewPassword" placeholder="Leave blank to keep current password" />
                <span class="form-hint">Set a new temporary password for the customer</span>
            </div>

            <div class="form-row" style="margin-top: 2rem;">
                <a href="/employee/customer/@Id" class="btn btn-secondary btn-full">Cancel</a>
                <button type="submit" class="btn btn-primary btn-full" disabled="@isLoading">
                    @(isLoading ? "Saving..." : "Save Changes")
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private EditCustomerModel model = new() { FirstName = "John", LastName = "Doe", PhoneNumber = "(555) 123-4567", Address = "123 Main St, NY" };
    private string? successMessage;
    private bool isLoading = false;

    private async Task HandleSubmit()
    {
        isLoading = true;
        successMessage = null;

        // TODO: Call API to update customer
        await Task.Delay(500);

        successMessage = "Customer information updated successfully.";
        isLoading = false;
    }

    public class EditCustomerModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string PhoneNumber { get; set; } = "";
        public string Address { get; set; } = "";
        public string NewPassword { get; set; } = "";
    }
}
