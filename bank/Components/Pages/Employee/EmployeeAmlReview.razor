@page "/employee/aml-review"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<PageTitle>AML Review – American Bank</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>Anti-Money Laundering Review</h1>
        <p class="page-subtitle">Review and manage flagged transactions</p>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Transactions Pending Review</h3>
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 2rem;">Loading AML transactions...</div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">@errorMessage</div>
        }
        else
        {
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in transactions)
                        {
                            <tr>
                                <td>@t.Timestamp.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>@t.CustomerName</td>
                                <td style="font-weight: 600;">$@t.Amount.ToString("N2")</td>
                                <td>@t.TransactionType</td>
                                <td>
                                    @if (t.Status == "AML_EXPLAINED")
                                    {
                                        <span class="badge badge-info">Explanation Provided</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning" style="background-color: orange; color: white;">Awaiting Customer</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-primary" @onclick="() => SelectTransaction(t)">Review</button>
                                </td>
                            </tr>
                        }
                        @if (!transactions.Any())
                        {
                            <tr><td colspan="6" style="text-align: center;">No flagged transactions at the moment.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Review Modal -->
    @if (selectedTransaction != null)
    {
        <div class="modal-overlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: center; justify-content: center;">
            <div class="modal-content" style="background: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border-color); padding: 2rem; border-radius: 8px; width: 500px; max-width: 90%; box-shadow: var(--shadow-lg);">
                <h3 style="margin-top: 0; color: var(--text-primary);">Review Transaction</h3>
                
                <div style="margin-bottom: 1rem; color: var(--text-secondary);">
                    <strong style="color: var(--text-primary);">Customer:</strong> @selectedTransaction.CustomerName<br/>
                    <strong style="color: var(--text-primary);">Amount:</strong> $@selectedTransaction.Amount.ToString("N2")<br/>
                    <strong style="color: var(--text-primary);">Date:</strong> @selectedTransaction.Timestamp.ToString("g")<br/>
                    <strong style="color: var(--text-primary);">Type:</strong> @selectedTransaction.TransactionType<br/>
                    <strong style="color: var(--text-primary);">Original Description:</strong> @selectedTransaction.Description
                </div>

                <div style="background-color: var(--bg-secondary); padding: 1rem; border-radius: 4px; margin-bottom: 1.5rem; border-left: 4px solid orange; color: var(--text-primary);">
                    <strong>Customer Explanation:</strong><br/>
                    @(string.IsNullOrWhiteSpace(selectedTransaction.AmlExplanation) ? "No explanation provided yet." : selectedTransaction.AmlExplanation)
                </div>

                <div style="display: flex; justify-content: space-between; gap: 10px;">
                    <button class="btn btn-ghost" @onclick="CloseModal" disabled="@isProcessing">Cancel</button>
                    <div style="display: flex; gap: 10px;">
                        <button class="btn btn-secondary" style="background-color: var(--accent-red); color: white; border-color: var(--accent-red);" @onclick="RejectTransaction" disabled="@isProcessing">Reject</button>
                        <button class="btn btn-primary" style="background-color: var(--accent-green); border-color: var(--accent-green);" @onclick="ApproveTransaction" disabled="@isProcessing">Approve & Execute</button>
                    </div>
                </div>

                @if (actionError != null)
                {
                    <div style="color: var(--accent-red); margin-top: 10px; font-size: 0.9em;">@actionError</div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private string? actionError;
    private bool isProcessing = false;
    private List<AmlTransactionItem> transactions = new();
    private AmlTransactionItem? selectedTransaction;

    public class AmlTransactionItem
    {
        public Guid Id { get; set; }
        public decimal Amount { get; set; }
        public string Currency { get; set; } = "USD";
        public DateTime Timestamp { get; set; }
        public string Status { get; set; } = "";
        public string Description { get; set; } = "";
        public string? AmlExplanation { get; set; }
        public string TransactionType { get; set; } = "";
        public string CustomerName { get; set; } = "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);
            var tokenResult = await SessionStorage.GetAsync<string>("authToken");
            if (tokenResult.Success && !string.IsNullOrEmpty(tokenResult.Value))
            {
                client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", tokenResult.Value);
            }

            var response = await client.GetAsync("api/transaction/aml-pending");
            if (response.IsSuccessStatusCode)
            {
                transactions = await response.Content.ReadFromJsonAsync<List<AmlTransactionItem>>() ?? new();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized || response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                errorMessage = "Failed to load AML transactions.";
            }
        }
        catch (Exception)
        {
            errorMessage = "A network error occurred while loading data.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectTransaction(AmlTransactionItem item)
    {
        selectedTransaction = item;
        actionError = null;
    }

    private void CloseModal()
    {
        selectedTransaction = null;
    }

    private async Task ApproveTransaction()
    {
        if (selectedTransaction == null) return;
        isProcessing = true;
        actionError = null;

        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);
            var tokenResult = await SessionStorage.GetAsync<string>("authToken");
            if (tokenResult.Success && !string.IsNullOrEmpty(tokenResult.Value))
            {
                client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", tokenResult.Value);
            }

            var response = await client.PostAsync($"api/transaction/approve-aml/{selectedTransaction.Id}", null);
            if (response.IsSuccessStatusCode)
            {
                CloseModal();
                await LoadData();
            }
            else
            {
                actionError = "Failed to approve transaction.";
                var errContent = await response.Content.ReadAsStringAsync();
                if (!string.IsNullOrEmpty(errContent)) actionError += " " + errContent;
            }
        }
        catch (Exception)
        {
            actionError = "A network error occurred.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task RejectTransaction()
    {
        if (selectedTransaction == null) return;
        isProcessing = true;
        actionError = null;

        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);
            var tokenResult = await SessionStorage.GetAsync<string>("authToken");
            if (tokenResult.Success && !string.IsNullOrEmpty(tokenResult.Value))
            {
                client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", tokenResult.Value);
            }

            var response = await client.PostAsync($"api/transaction/reject-aml/{selectedTransaction.Id}", null);
            if (response.IsSuccessStatusCode)
            {
                CloseModal();
                await LoadData();
            }
            else
            {
                actionError = "Failed to reject transaction.";
            }
        }
        catch (Exception)
        {
            actionError = "A network error occurred.";
        }
        finally
        {
            isProcessing = false;
        }
    }
}
