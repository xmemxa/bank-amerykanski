@page "/employee/dashboard"
@rendermode InteractiveServer

<PageTitle>Employee Dashboard – American Bank</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>Employee Dashboard</h1>
        <p class="page-subtitle">Overview of today's banking operations</p>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Total Customers</div>
            <div class="stat-value">1,247</div>
            <div class="stat-change stat-change-up">+12 this month</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Active Accounts</div>
            <div class="stat-value">2,031</div>
            <div class="stat-change stat-change-up">+18 this month</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Today's Transactions</div>
            <div class="stat-value">89</div>
            <div class="stat-change">$284,520.00 volume</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Pending Approvals</div>
            <div class="stat-value">3</div>
            <div class="stat-change stat-change-warn">Requires attention</div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
        <a href="/employee/create-customer" class="btn btn-primary btn-lg">Create New Customer</a>
        <a href="/employee/customers" class="btn btn-secondary btn-lg">Search Customers</a>
    </div>

    <!-- Recently Created Accounts -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Recently Created Accounts</h3>
            <a href="/employee/customers" class="btn btn-ghost">View All</a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Account Type</th>
                        <th>Account Number</th>
                        <th>Created By</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>May 12, 2026</td>
                        <td style="font-weight: 600; color: var(--text-primary);">Sarah Johnson</td>
                        <td>sarah.johnson@email.com</td>
                        <td><span class="badge badge-info">Checking</span></td>
                        <td style="font-family: monospace;">0098761234</td>
                        <td>Admin</td>
                    </tr>
                    <tr>
                        <td>May 11, 2026</td>
                        <td style="font-weight: 600; color: var(--text-primary);">Michael Chen</td>
                        <td>m.chen@email.com</td>
                        <td><span class="badge badge-info">Savings</span></td>
                        <td style="font-family: monospace;">0098765678</td>
                        <td>Admin</td>
                    </tr>
                    <tr>
                        <td>May 10, 2026</td>
                        <td style="font-weight: 600; color: var(--text-primary);">Emily Davis</td>
                        <td>emily.d@email.com</td>
                        <td><span class="badge badge-info">Checking</span></td>
                        <td style="font-family: monospace;">0098769012</td>
                        <td>Admin</td>
                    </tr>
                    <tr>
                        <td>May 9, 2026</td>
                        <td style="font-weight: 600; color: var(--text-primary);">James Wilson</td>
                        <td>j.wilson@email.com</td>
                        <td><span class="badge badge-info">Checking</span></td>
                        <td style="font-family: monospace;">0098763456</td>
                        <td>Admin</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
