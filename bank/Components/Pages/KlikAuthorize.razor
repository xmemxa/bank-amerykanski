@page "/klik/authorize"
@using bank.Services.Klik
@using bank.Providers
@using bank.Services
@using bank.Data
@using bank.Models
@using Microsoft.EntityFrameworkCore
@using System.Threading
@using Microsoft.AspNetCore.Components.Authorization
@inject KlikService KlikService
@inject AuthenticationStateProvider AuthStateProvider
@inject BankDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Authorize Payments</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>Authorize KLIK Payments</h1>
        <p class="page-subtitle">Review and confirm pending KLIK transactions.</p>
    </div>

    @if (isLoading)
    {
        <div style="display: flex; justify-content: center; padding: 2rem;">
            <span>Loading...</span>
        </div>
    }
    else if (!pendingAuths.Any())
    {
        <div class="card" style="text-align: center; padding: 3rem;">
            <h3 class="card-title">No pending authorizations</h3>
            <p style="color: var(--text-muted); margin-top: 0.5rem;">You don't have any KLIK payments waiting for your approval right now.</p>
        </div>
    }
    else
    {
        <div style="display: grid; gap: 1rem;">
            @foreach (var auth in pendingAuths)
            {
                <div class="card" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; padding: 1.5rem; flex-wrap: wrap; gap: 1rem;">
                    <div style="display: flex; gap: 1rem; align-items: center;">
                        <div style="background-color: rgba(59, 130, 246, 0.1); padding: 0.75rem; border-radius: 50%;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><path d="M2 7h20"/><path d="M22 7v3a2 2 0 0 1-2 2v0a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 16 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 12 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 8 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 4 12v0a2 2 0 0 1-2-2V7"/></svg>
                        </div>
                        <div>
                            <h3 style="margin: 0; font-size: 1.125rem; font-weight: 600;">@auth.MerchantName</h3>
                            <p style="margin: 0; color: var(--text-muted); font-size: 0.875rem;">KLIK Payment</p>
                            <p style="margin: 0; color: var(--text-muted); font-size: 0.75rem;">Expires: @auth.ExpiryTime.ToLocalTime().ToString("HH:mm:ss")</p>
                        </div>
                    </div>
                    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem;">
                        <div style="font-size: 1.5rem; font-weight: 700;">@auth.Amount.ToString("C")</div>
                        <div style="display: flex; gap: 0.5rem;">
                            <button @onclick="() => HandleDecision(auth, false)" class="btn btn-secondary">
                                Reject
                            </button>
                            <button @onclick="() => HandleDecision(auth, true)" class="btn btn-primary">
                                Authorize
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<KlikPendingAuthorization> pendingAuths = new();
    private bool isLoading = true;
    private User? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst("id")?.Value;
        if (!string.IsNullOrEmpty(userIdStr) && Guid.TryParse(userIdStr, out var userId))
        {
            currentUser = await DbContext.Users.FindAsync(userId);
        }
        
        await LoadPendingAuths();
    }

    private async Task LoadPendingAuths()
    {
        if (currentUser == null) return;
        
        isLoading = true;
        
        // Remove expired
        var expired = await DbContext.KlikPendingAuthorizations
            .Where(a => a.UserId == currentUser.Id.ToString() && a.Status == "PENDING" && a.ExpiryTime < DateTime.UtcNow)
            .ToListAsync();
            
        foreach(var e in expired)
        {
            e.Status = "EXPIRED";
        }
        
        if (expired.Any()) await DbContext.SaveChangesAsync();

        pendingAuths = await DbContext.KlikPendingAuthorizations
            .Where(a => a.UserId == currentUser.Id.ToString() && a.Status == "PENDING" && a.ExpiryTime >= DateTime.UtcNow)
            .OrderBy(a => a.ExpiryTime)
            .ToListAsync();
            
        isLoading = false;
    }

    private async Task HandleDecision(KlikPendingAuthorization auth, bool isAccepted)
    {
        // Sprawdzamy czy mamy wystarczające środki, jeżeli akceptujemy
        if (isAccepted)
        {
            var userAccount = await DbContext.Accounts.FirstOrDefaultAsync(a => a.UserId == currentUser!.Id);
            if (userAccount == null || userAccount.Balance < auth.Amount)
            {
                // Odrzuć z powodu braku środków
                await KlikService.ConfirmPaymentAsync(auth.TransactionId, "REJECTED", "INSUFFICIENT_FUNDS");
                auth.Status = "REJECTED";
                await DbContext.SaveChangesAsync();
                await LoadPendingAuths();
                // Pokazujemy alert / komunikat?
                return;
            }

            // Realizujemy płatność
            userAccount.Balance -= auth.Amount;
            
            var tx = new Transaction
            {
                Id = Guid.NewGuid(),
                FromAccountId = userAccount.Id,
                Amount = auth.Amount,
                Currency = auth.Currency,
                Description = $"KLIK Payment: {auth.MerchantName}",
                Status = "Completed",
                TransactionType = "KLIK"
            };
            
            DbContext.Transactions.Add(tx);
            auth.Status = "ACCEPTED";
            await DbContext.SaveChangesAsync();

            await KlikService.ConfirmPaymentAsync(auth.TransactionId, "ACCEPTED");
        }
        else
        {
            auth.Status = "REJECTED";
            await DbContext.SaveChangesAsync();
            await KlikService.ConfirmPaymentAsync(auth.TransactionId, "REJECTED", "USER_DECLINED");
        }

        await LoadPendingAuths();
    }
}
