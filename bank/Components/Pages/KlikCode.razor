@page "/klik/code"
@using bank.Services.Klik
@using bank.Providers
@using bank.Services
@using System.Threading
@using Microsoft.AspNetCore.Components.Authorization
@inject KlikService KlikService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>KLIK Code</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>Generate KLIK Code</h1>
        <p class="page-subtitle">Generate a 6-digit code to pay in stores or online.</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Your Code</h3>
            </div>
            <div style="padding: 1.5rem; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 200px;">
                @if (isLoading)
                {
                    <div style="margin-bottom: 1rem;">Loading...</div>
                }
                else if (!string.IsNullOrEmpty(klikCode))
                {
                    <div style="font-size: 3.75rem; font-weight: 700; letter-spacing: 0.2em; color: var(--primary); margin-bottom: 1rem; font-family: monospace;">
                        @klikCode.Substring(0, 3) @klikCode.Substring(3, 3)
                    </div>
                    <div style="font-size: 0.875rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.5rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" x2="14" y1="2" y2="2"/><line x1="12" x2="15" y1="14" y2="11"/><circle cx="12" cy="14" r="8"/></svg>
                        Expires in: <span style="font-weight: 500; color: var(--text-primary);">@timeLeft s</span>
                    </div>
                }
                else if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-error">
                        @errorMessage
                    </div>
                }
                else
                {
                    <p style="color: var(--text-muted); text-align: center; margin-bottom: 1.5rem;">Click the button below to generate a new KLIK payment code.</p>
                }

                <button @onclick="GenerateCode" disabled="@(isLoading || (!string.IsNullOrEmpty(klikCode) && timeLeft > 0))"
                        class="btn btn-primary" style="margin-top: 1.5rem; width: 100%; max-width: 200px;">
                    @(string.IsNullOrEmpty(klikCode) ? "Generate Code" : "Generating...")
                </button>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">How it works</h3>
            </div>
            <div style="padding: 1.5rem; font-size: 0.875rem; color: var(--text-muted);">
                <ol style="padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem;">
                    <li>Generate a 6-digit code using the button on the left.</li>
                    <li>Tell the cashier you want to pay with KLIK, or select KLIK online.</li>
                    <li>Enter the 6-digit code on the payment terminal or website.</li>
                    <li>Wait for a push notification or check the <strong>Authorize Payments</strong> tab.</li>
                    <li>Confirm the payment with your PIN/password to complete the transaction.</li>
                </ol>
            </div>
        </div>
    </div>
</div>

@code {
    private string klikCode = string.Empty;
    private int timeLeft = 0;
    private bool isLoading = false;
    private string errorMessage = string.Empty;
    private Timer? timer;

    private async Task GenerateCode()
    {
        isLoading = true;
        errorMessage = string.Empty;
        klikCode = string.Empty;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userIdStr = authState.User.FindFirst("id")?.Value;
            
            if (string.IsNullOrEmpty(userIdStr))
            {
                errorMessage = "You must be logged in to generate a code.";
                return;
            }

            var result = await KlikService.GenerateCodeAsync(userIdStr);
            klikCode = result.Code;
            timeLeft = result.ExpiresIn;
            
            StartTimer();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartTimer()
    {
        timer?.Dispose();
        timer = new Timer(_ =>
        {
            if (timeLeft > 0)
            {
                timeLeft--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                klikCode = string.Empty;
                timer?.Dispose();
                InvokeAsync(StateHasChanged);
            }
        }, null, 1000, 1000);
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}
