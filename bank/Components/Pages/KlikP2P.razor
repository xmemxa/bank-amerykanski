@page "/klik/p2p"
@using bank.Services.Klik
@using bank.Services.ExternalPayments
@using bank.Providers
@using bank.Services
@using bank.Data
@using bank.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.Json
@inject KlikP2PService KlikP2PService
@inject FedNowService FedNowService
@inject AuthenticationStateProvider AuthStateProvider
@inject BankDbContext DbContext

<PageTitle>KLIK P2P Transfer</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>KLIK Transfer to Phone</h1>
        <p class="page-subtitle">Send money instantly using just a phone number, or register your own number.</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
        <!-- Send Money Form -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Send Money</h3>
            </div>
            <div style="padding: 1.5rem;">
                <EditForm Model="transferModel" OnValidSubmit="HandleSendMoney">
                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label class="form-label">Recipient Phone Number (e.g. +15551234567)</label>
                        <InputText @bind-Value="transferModel.Phone" class="form-input" placeholder="+1..." />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Amount (USD)</label>
                        <InputNumber @bind-Value="transferModel.Amount" class="form-input" min="0.01" step="0.01" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Description</label>
                        <InputText @bind-Value="transferModel.Description" class="form-input" placeholder="Transfer description" />
                    </div>

                    @if (!string.IsNullOrEmpty(sendErrorMessage))
                    {
                        <div class="alert alert-error">@sendErrorMessage</div>
                    }

                    @if (!string.IsNullOrEmpty(sendSuccessMessage))
                    {
                        <div class="alert alert-success">@sendSuccessMessage</div>
                    }

                    <button type="submit" disabled="@isSending" class="btn btn-primary btn-full" style="margin-top: 1rem;">
                        @if (isSending)
                        {
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>Send instantly via KLIK</span>
                        }
                    </button>
                </EditForm>
            </div>
        </div>

        <!-- Manage Alias -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Receive Money (Register Phone)</h3>
            </div>
            <div style="padding: 1.5rem;">
                <p style="color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1.5rem;">
                    Register your phone number to receive transfers instantly from anyone using KLIK P2P.
                </p>
                
                <div class="form-group">
                    <label class="form-label">Your Phone Number</label>
                    <input @bind="registerPhone" class="form-input" placeholder="+1..." />
                </div>

                @if (!string.IsNullOrEmpty(registerErrorMessage))
                {
                    <div class="alert alert-error">@registerErrorMessage</div>
                }

                @if (!string.IsNullOrEmpty(registerSuccessMessage))
                {
                    <div class="alert alert-success">@registerSuccessMessage</div>
                }

                <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
                    <button @onclick="RegisterAlias" disabled="@isRegistering" class="btn btn-primary" style="flex: 1;">
                        Register
                    </button>
                    <button @onclick="DeleteAlias" disabled="@isRegistering" class="btn btn-secondary" style="flex: 1;">
                        Unregister
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private class TransferModel
    {
        public string Phone { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public string Description { get; set; } = string.Empty;
    }

    private TransferModel transferModel = new();
    private string registerPhone = string.Empty;
    
    private bool isSending = false;
    private bool isRegistering = false;
    
    private string sendErrorMessage = string.Empty;
    private string sendSuccessMessage = string.Empty;
    
    private string registerErrorMessage = string.Empty;
    private string registerSuccessMessage = string.Empty;

    private User? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst("id")?.Value;
        if (!string.IsNullOrEmpty(userIdStr) && Guid.TryParse(userIdStr, out var userId))
        {
            currentUser = await DbContext.Users.FindAsync(userId);
        }
    }

    private async Task HandleSendMoney()
    {
        isSending = true;
        sendErrorMessage = string.Empty;
        sendSuccessMessage = string.Empty;

        try
        {
            if (currentUser == null) throw new Exception("User not found.");
            if (string.IsNullOrWhiteSpace(transferModel.Phone)) throw new Exception("Phone is required.");
            if (transferModel.Amount <= 0) throw new Exception("Amount must be greater than 0.");

            var senderAccount = await DbContext.Accounts.FirstOrDefaultAsync(a => a.UserId == currentUser.Id);
            if (senderAccount == null) throw new Exception("Account not found.");
            if (senderAccount.Balance < transferModel.Amount) throw new Exception("Insufficient funds.");

            if (senderAccount.AccountType == "Junior")
            {
                var dto = new TransferRequestDto
                {
                    FromAccount = senderAccount.AccountNumber,
                    ToAccount = transferModel.Phone, // we store phone as ToAccount
                    Amount = transferModel.Amount,
                    Description = transferModel.Description,
                    TransactionType = "KLIK"
                };

                var pendingTx = new Transaction
                {
                    Id = Guid.NewGuid(),
                    FromAccountId = senderAccount.Id,
                    Amount = transferModel.Amount,
                    Currency = "USD",
                    Description = $"Pending KLIK P2P to {transferModel.Phone}: {transferModel.Description}",
                    Status = "Pending_Approval",
                    TransactionType = "KLIK",
                    TransferRequestJson = JsonSerializer.Serialize(dto)
                };

                DbContext.Transactions.Add(pendingTx);
                await DbContext.SaveChangesAsync();

                sendSuccessMessage = "Transfer requested and is pending parent approval.";
                transferModel = new TransferModel(); // Reset form
                return;
            }

            // 1. Lookup the alias in KLIK
            var lookupResult = await KlikP2PService.LookupAliasAsync(transferModel.Phone);
            if (lookupResult == null)
            {
                throw new Exception("Phone number is not registered in KLIK P2P.");
            }

            // 2. Perform the actual transfer via FedNow
            var (recipientRouting, recipientAccount) = lookupResult.Value;

            // FedNow fee is usually $0.50 but P2P might be free or differently priced. We'll stick to our standard.
            decimal fee = 0.50m;
            if (senderAccount.Balance < transferModel.Amount + fee) throw new Exception($"Insufficient funds for amount + ${fee} FedNow fee.");

            var txId = Guid.NewGuid();
            var result = await FedNowService.SendInstantTransferAsync(
                txId,
                senderAccount.Id.ToString(),
                transferModel.Amount,
                recipientRouting,
                recipientAccount,
                transferModel.Description
            );

            if (!result.IsSuccess)
            {
                throw new Exception($"FedNow transfer failed: {result.Error}");
            }

            // 3. Save transactions
            senderAccount.Balance -= (transferModel.Amount + fee);

            var tx = new Transaction
            {
                Id = txId,
                FromAccountId = senderAccount.Id,
                Amount = transferModel.Amount,
                Currency = "USD",
                Description = $"KLIK P2P to {transferModel.Phone}: {transferModel.Description}",
                Status = "Completed",
                TransactionType = "FEDNOW",
                ExternalDestinationAccount = recipientAccount
            };

            var feeTx = new Transaction
            {
                Id = Guid.NewGuid(),
                FromAccountId = senderAccount.Id,
                Amount = fee,
                Currency = "USD",
                Description = "FedNow P2P Transfer Fee",
                Status = "Completed",
                TransactionType = "Fee"
            };

            DbContext.Transactions.Add(tx);
            DbContext.Transactions.Add(feeTx);
            await DbContext.SaveChangesAsync();

            sendSuccessMessage = "Transfer sent successfully!";
            transferModel = new TransferModel(); // Reset form
        }
        catch (Exception ex)
        {
            sendErrorMessage = ex.Message;
        }
        finally
        {
            isSending = false;
        }
    }

    private async Task RegisterAlias()
    {
        isRegistering = true;
        registerErrorMessage = string.Empty;
        registerSuccessMessage = string.Empty;

        try
        {
            if (currentUser == null) throw new Exception("User not found.");
            if (string.IsNullOrWhiteSpace(registerPhone)) throw new Exception("Phone is required.");

            var myAccount = await DbContext.Accounts.FirstOrDefaultAsync(a => a.UserId == currentUser.Id);
            if (myAccount == null) throw new Exception("Account not found.");

            // Standardowe mockowane routing number dla American Bank to 040104018
            var success = await KlikP2PService.RegisterAliasAsync(registerPhone, "040104018", myAccount.AccountNumber);
            if (success)
            {
                registerSuccessMessage = "Phone number registered successfully!";
            }
            else
            {
                registerErrorMessage = "Failed to register alias. It might be already in use.";
            }
        }
        catch (Exception ex)
        {
            registerErrorMessage = ex.Message;
        }
        finally
        {
            isRegistering = false;
        }
    }

    private async Task DeleteAlias()
    {
        isRegistering = true;
        registerErrorMessage = string.Empty;
        registerSuccessMessage = string.Empty;

        try
        {
            if (string.IsNullOrWhiteSpace(registerPhone)) throw new Exception("Phone is required to delete.");
            var success = await KlikP2PService.DeleteAliasAsync(registerPhone);
            if (success)
            {
                registerSuccessMessage = "Alias unregistered successfully.";
            }
            else
            {
                registerErrorMessage = "Failed to unregister. Not found or you don't own it.";
            }
        }
        catch (Exception ex)
        {
            registerErrorMessage = ex.Message;
        }
        finally
        {
            isRegistering = false;
        }
    }
}
