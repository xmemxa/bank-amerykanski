@page "/history"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<PageTitle>Transaction History – American Bank</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>Transaction History</h1>
        <p class="page-subtitle">View and filter all your account activity</p>
    </div>

    <!-- Filters -->
    <div class="filter-bar">
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">From Date</label>
            <InputDate class="form-input" @bind-Value="filterFrom" />
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">To Date</label>
            <InputDate class="form-input" @bind-Value="filterTo" />
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Type</label>
            <select class="form-select" @bind="filterType">
                <option value="">All Types</option>
                <option value="Internal">Internal</option>
                <option value="ACH">ACH</option>
                <option value="FedNow">FedNow</option>
                <option value="Wire">Wire</option>
                <option value="SWIFT">SWIFT</option>
                <option value="RTP">RTP</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Status</label>
            <select class="form-select" @bind="filterStatus">
                <option value="">All Statuses</option>
                <option value="Completed">Completed</option>
                <option value="Pending">Pending</option>
                <option value="Failed">Failed</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 0; display: flex; align-items: flex-end;">
            <button class="btn btn-primary" @onclick="ApplyFilters">Search</button>
        </div>
    </div>

    <!-- Results -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Results (@filteredTransactions.Count transactions)</h3>
            <button class="btn btn-ghost">Export CSV ↓</button>
        </div>

        <div class="table-container">
            @if (isLoading)
            {
                <div style="text-align: center; padding: 2rem;">Loading history...</div>
            }
            else if (errorMessage != null)
            {
                <div style="text-align: center; color: var(--error); padding: 1rem;">@errorMessage</div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Description</th>
                            <th>E2E ID</th>
                            <th>Type</th>
                            <th>Account</th>
                            <th>Status</th>
                            <th style="text-align: right;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in filteredTransactions)
                        {
                            <tr>
                                <td>@t.Timestamp.ToString("MMM dd, yyyy")</td>
                                <td>@t.Description</td>
                                <td><small class="text-muted">@t.EndToEndId</small></td>
                                <td><span class="badge badge-info">@t.TransactionType</span></td>
                                <td>
                                    @(string.IsNullOrEmpty(t.AccountDisplay) ? "External" : $"••••{(t.AccountDisplay.Length >= 4 ? t.AccountDisplay.Substring(t.AccountDisplay.Length - 4) : t.AccountDisplay)}")
                                </td>
                                <td>
                                    @if (t.Status == "Completed")
                                    {
                                        <span class="badge badge-completed">Completed</span>
                                    }
                                    else if (t.Status == "Pending")
                                    {
                                        <span class="badge badge-pending">Pending</span>
                                    }
                                    else if (t.Status == "AML_HOLD")
                                    {
                                        <span class="badge badge-failed" style="background-color: orange; color: white;">AML Hold</span>
                                        <button class="btn btn-sm btn-primary" style="margin-left: 5px; padding: 2px 8px; font-size: 0.8em;" @onclick="() => OpenAmlModal(t.Id)">Explain</button>
                                    }
                                    else if (t.Status == "AML_EXPLAINED")
                                    {
                                        <span class="badge badge-info">AML In Review</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-failed">@t.Status</span>
                                    }
                                </td>
                                <td style="text-align: right;" class="amount @(t.IsCredit ? "amount-positive" : "amount-negative")">
                                    @(t.IsCredit ? "+" : "−")$@t.Amount.ToString("N2")
                                </td>
                            </tr>
                        }
                        @if (!filteredTransactions.Any())
                        {
                            <tr><td colspan="6" style="text-align: center;">No transactions found.</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- AML Explanation Modal -->
    @if (showAmlModal)
    {
        <div class="modal-overlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: center; justify-content: center;">
            <div class="modal-content" style="background: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border-color); padding: 2rem; border-radius: 8px; width: 400px; max-width: 90%; box-shadow: var(--shadow-lg);">
                <h3 style="margin-top: 0; color: var(--text-primary);">AML Review Required</h3>
                <p style="color: var(--text-secondary);">Your transaction has been flagged by our compliance system. Please provide a brief explanation for this transfer to proceed.</p>
                <textarea class="form-input" rows="4" @bind="amlExplanationText" placeholder="E.g., Payment for freelance design work..."></textarea>
                <div style="margin-top: 1rem; display: flex; justify-content: flex-end; gap: 10px;">
                    <button class="btn btn-ghost" @onclick="CloseAmlModal" disabled="@isSubmittingAml">Cancel</button>
                    <button class="btn btn-primary" @onclick="SubmitAmlExplanation" disabled="@isSubmittingAml">Submit Explanation</button>
                </div>
                @if (amlError != null)
                {
                    <div style="color: var(--accent-red); margin-top: 10px; font-size: 0.9em;">@amlError</div>
                }
            </div>
        </div>
    }
</div>

@code {
    private DateTime? filterFrom = DateTime.Today.AddMonths(-1);
    private DateTime? filterTo = DateTime.Today;
    private string filterType = "";
    private string filterStatus = "";

    private bool isLoading = true;
    private string? errorMessage;
    private List<TransactionHistoryItem> allTransactions = new();
    private List<TransactionHistoryItem> filteredTransactions = new();

    private bool showAmlModal = false;
    private Guid? amlTransactionId = null;
    private string amlExplanationText = "";
    private bool isSubmittingAml = false;
    private string? amlError = null;

    private void OpenAmlModal(Guid id)
    {
        amlTransactionId = id;
        amlExplanationText = "";
        amlError = null;
        showAmlModal = true;
    }

    private void CloseAmlModal()
    {
        showAmlModal = false;
        amlTransactionId = null;
    }

    private async Task SubmitAmlExplanation()
    {
        if (amlTransactionId == null) return;
        isSubmittingAml = true;
        amlError = null;

        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);
            var tokenResult = await SessionStorage.GetAsync<string>("authToken");
            if (tokenResult.Success && !string.IsNullOrEmpty(tokenResult.Value))
            {
                client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", tokenResult.Value);
            }

            var request = new { Explanation = amlExplanationText };
            var response = await client.PostAsJsonAsync($"api/transaction/explain-aml/{amlTransactionId}", request);
            
            if (response.IsSuccessStatusCode)
            {
                CloseAmlModal();
                await LoadData(); // Reload the history
            }
            else
            {
                amlError = "Submission failed.";
            }
        }
        catch (Exception)
        {
            amlError = "A network error occurred.";
        }
        finally
        {
            isSubmittingAml = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);
            
            var tokenResult = await SessionStorage.GetAsync<string>("authToken");
            if (tokenResult.Success && !string.IsNullOrEmpty(tokenResult.Value))
            {
                client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", tokenResult.Value);
            }
            else
            {
                errorMessage = "Authentication token missing. Please log in again.";
                isLoading = false;
                return;
            }
            
            var response = await client.GetAsync("api/transaction/history");
            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<List<TransactionHistoryItem>>();
                if (data != null)
                {
                    allTransactions = data;
                    ApplyFilters();
                }
            }
            else
            {
                errorMessage = "Failed to load transaction history.";
            }
        }
        catch (Exception)
        {
            errorMessage = "A network error occurred. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        filteredTransactions = allTransactions.Where(t => 
            (!filterFrom.HasValue || t.Timestamp.Date >= filterFrom.Value.Date) &&
            (!filterTo.HasValue || t.Timestamp.Date <= filterTo.Value.Date) &&
            (string.IsNullOrEmpty(filterType) || t.TransactionType == filterType) &&
            (string.IsNullOrEmpty(filterStatus) || t.Status == filterStatus)
        ).ToList();
    }

    public class TransactionHistoryItem
    {
        public Guid Id { get; set; }
        public DateTime Timestamp { get; set; }
        public string Description { get; set; } = "";
        public string TransactionType { get; set; } = "";
        public string EndToEndId { get; set; } = "";
        public string Status { get; set; } = "";
        public decimal Amount { get; set; }
        public string Currency { get; set; } = "USD";
        public bool IsCredit { get; set; }
        public string AccountDisplay { get; set; } = "";
    }
}
