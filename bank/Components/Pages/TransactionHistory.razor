@page "/history"
@rendermode InteractiveServer

<PageTitle>Transaction History – American Bank</PageTitle>

<div class="fade-in">
    <div class="page-header">
        <h1>Transaction History</h1>
        <p class="page-subtitle">View and filter all your account activity</p>
    </div>

    <!-- Filters -->
    <div class="filter-bar">
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">From Date</label>
            <InputDate class="form-input" @bind-Value="filterFrom" />
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">To Date</label>
            <InputDate class="form-input" @bind-Value="filterTo" />
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Type</label>
            <select class="form-select" @bind="filterType">
                <option value="">All Types</option>
                <option value="Internal">Internal</option>
                <option value="ACH">ACH</option>
                <option value="FedNow">FedNow</option>
                <option value="Wire">Wire</option>
                <option value="SWIFT">SWIFT</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Status</label>
            <select class="form-select" @bind="filterStatus">
                <option value="">All Statuses</option>
                <option value="Completed">Completed</option>
                <option value="Pending">Pending</option>
                <option value="Failed">Failed</option>
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 0; display: flex; align-items: flex-end;">
            <button class="btn btn-primary" @onclick="ApplyFilters">Search</button>
        </div>
    </div>

    <!-- Results -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Results (12 transactions)</h3>
            <button class="btn btn-ghost">Export CSV ↓</button>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Account</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th style="text-align: right;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>May 12, 2026</td>
                        <td>Payroll Deposit – Acme Corp</td>
                        <td>Checking ••••4521</td>
                        <td><span class="badge badge-info">ACH</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-positive">+$3,450.00</td>
                    </tr>
                    <tr>
                        <td>May 11, 2026</td>
                        <td>Transfer to Savings</td>
                        <td>Checking ••••4521</td>
                        <td><span class="badge badge-info">Internal</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-negative">−$500.00</td>
                    </tr>
                    <tr>
                        <td>May 11, 2026</td>
                        <td>Transfer from Checking</td>
                        <td>Savings ••••7832</td>
                        <td><span class="badge badge-info">Internal</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-positive">+$500.00</td>
                    </tr>
                    <tr>
                        <td>May 10, 2026</td>
                        <td>Wire to ABC Realty</td>
                        <td>Checking ••••4521</td>
                        <td><span class="badge badge-info">Wire</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-negative">−$2,100.00</td>
                    </tr>
                    <tr>
                        <td>May 9, 2026</td>
                        <td>FedNow from Jane Smith</td>
                        <td>Checking ••••4521</td>
                        <td><span class="badge badge-info">FedNow</span></td>
                        <td><span class="badge badge-pending">Pending</span></td>
                        <td style="text-align: right;" class="amount amount-positive">+$250.00</td>
                    </tr>
                    <tr>
                        <td>May 8, 2026</td>
                        <td>SWIFT – London Office</td>
                        <td>Checking ••••4521</td>
                        <td><span class="badge badge-info">SWIFT</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-negative">−$5,000.00</td>
                    </tr>
                    <tr>
                        <td>May 7, 2026</td>
                        <td>ACH – Utility Bill</td>
                        <td>Checking ••••4521</td>
                        <td><span class="badge badge-info">ACH</span></td>
                        <td><span class="badge badge-completed">Completed</span></td>
                        <td style="text-align: right;" class="amount amount-negative">−$127.50</td>
                    </tr>
                    <tr>
                        <td>May 5, 2026</td>
                        <td>Venmo Refund</td>
                        <td>Checking ••••4521</td>
                        <td><span class="badge badge-info">ACH</span></td>
                        <td><span class="badge badge-failed">Failed</span></td>
                        <td style="text-align: right;" class="amount amount-positive">+$45.00</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private DateTime? filterFrom = DateTime.Today.AddMonths(-1);
    private DateTime? filterTo = DateTime.Today;
    private string filterType = "";
    private string filterStatus = "";

    private void ApplyFilters()
    {
        // TODO: Call API with filters
    }
}
