@page "/transfer/ach"
@rendermode InteractiveServer

<PageTitle>ACH Transfer – American Bank</PageTitle>

<div class="fade-in transfer-page-center">
    <div class="page-header">
        <h1>ACH Transfer</h1>
        <p class="page-subtitle">Standard domestic bank transfer · Settlement: 1–3 business days</p>
    </div>

    <div class="card">
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">@errorMessage</div>
        }

        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="AchTransfer">
            <div class="form-group">
                <label class="form-label">From Account</label>
                <InputSelect class="form-select" @bind-Value="model.FromAccount">
                    <option value="">Select source account</option>
                    <option value="checking">Primary Checking (····4521) – $12,458.32</option>
                    <option value="savings">Emergency Fund (····7832) – $45,230.00</option>
                </InputSelect>
            </div>

            <h3 style="margin: 1.5rem 0 1rem; color: var(--text-secondary); font-size: 0.875rem;">Recipient Details</h3>

            <div class="form-group">
                <label class="form-label">Recipient's Routing Number (ABA)</label>
                <InputText class="form-input" @bind-Value="model.RoutingNumber" placeholder="9 digits, e.g. 021000021" maxlength="9" />
                <span class="form-hint">The 9-digit ABA routing number of the recipient's bank</span>
            </div>

            <div class="form-group">
                <label class="form-label">Recipient's Account Number</label>
                <InputText class="form-input" @bind-Value="model.AccountNumber" placeholder="Account number" />
            </div>

            <div class="form-group">
                <label class="form-label">Recipient Name</label>
                <InputText class="form-input" @bind-Value="model.RecipientName" placeholder="Full legal name" />
            </div>

            <div class="form-group">
                <label class="form-label">Amount (USD)</label>
                <InputNumber class="form-input" @bind-Value="model.Amount" placeholder="0.00" />
            </div>

            <div class="form-group">
                <label class="form-label">Memo (Optional)</label>
                <InputText class="form-input" @bind-Value="model.Description" placeholder="e.g., Invoice #12345" />
            </div>

            <div class="alert alert-info" style="margin-top: 1.5rem;">
                ACH transfers are batched and settled via the Automated Clearing House network. Typical processing: T+1 to T+3 business days. No fee for standard ACH.
            </div>

            <button type="submit" class="btn btn-primary btn-lg btn-full" style="margin-top: 1rem;" disabled="@isLoading">
                @(isLoading ? "Submitting..." : "Send ACH Transfer")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private AchModel model = new();
    private string? successMessage;
    private string? errorMessage;
    private bool isLoading = false;

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;
        await Task.Delay(500);
        successMessage = $"ACH transfer of ${model.Amount:N2} submitted. Settlement expected in 1–3 business days.";
        isLoading = false;
    }

    public class AchModel
    {
        public string FromAccount { get; set; } = "";
        public string RoutingNumber { get; set; } = "";
        public string AccountNumber { get; set; } = "";
        public string RecipientName { get; set; } = "";
        public decimal Amount { get; set; }
        public string Description { get; set; } = "";
    }
}
