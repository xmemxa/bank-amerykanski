@page "/transfer/internal"
@page "/transfer"
@using System.ComponentModel.DataAnnotations
@using bank.Models
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject IServiceProvider ServiceProvider
@rendermode InteractiveServer

<PageTitle>Transfer Funds – American Bank</PageTitle>

<div class="fade-in transfer-page-center">
    <div class="page-header">
        <h1>Transfer Funds</h1>
        <p class="page-subtitle">Move money internally or to external accounts via ACH, FedNow, or RTP</p>
    </div>

    <div class="card">
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">@errorMessage</div>
        }

        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="TransferFunds">
            <DataAnnotationsValidator />
            
            <div class="form-group">
                <label class="form-label">Transfer Type</label>
                <InputSelect class="form-select" @bind-Value="model.TransactionType">
                    <option value="Internal">Internal Transfer (Instant, Free)</option>
                    <option value="ACH">ACH Transfer (1-3 days, Free)</option>
                    <option value="FedNow">FedNow Instant (Instant, $0.50 fee)</option>
                    <option value="RTP">RTP System (Instant, Free)</option>
                </InputSelect>
            </div>

            <div class="form-group">
                <label class="form-label">From Account</label>
                <InputSelect class="form-input" @bind-Value="model.FromAccount">
                    @if (!myAccounts.Any())
                    {
                        <option value="">Loading accounts...</option>
                    }
                    else
                    {
                        @foreach (var acc in myAccounts)
                        {
                            <option value="@acc.AccountNumber">@acc.AccountType - @acc.AccountNumber (Balance: $@acc.Balance.ToString("N2"))</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => model.FromAccount)" class="text-danger" />
            </div>

            @if (model.TransactionType == "Internal")
            {
                <div class="form-group">
                    <label class="form-label">To Account (Internal)</label>
                    <InputText class="form-input" @bind-Value="model.ToAccount" placeholder="e.g. 0987654321" />
                    <ValidationMessage For="@(() => model.ToAccount)" class="text-danger" />
                </div>
            }
            else
            {
                <h3 style="margin: 1.5rem 0 1rem; color: var(--text-secondary); font-size: 0.875rem;">External Recipient Details</h3>
                <div class="form-group">
                    <label class="form-label">Recipient's Routing Number / Bank Code</label>
                    <InputText class="form-input" @bind-Value="model.TargetRoutingNumber" placeholder="@GetRoutingPlaceholder()" />
                    <small style="color: var(--text-secondary); font-size: 0.75rem;">
                        @if (model.TransactionType == "RTP") { <text>RTP bank code, e.g. BANKB</text> }
                        else if (model.TransactionType == "FedNow") { <text>FedNow bank code, e.g. BANKB</text> }
                        else { <text>9-digit routing number, e.g. 010101012</text> }
                    </small>
                </div>

                <div class="form-group">
                    <label class="form-label">Recipient's Account Number</label>
                    <InputText class="form-input" @bind-Value="model.ExternalAccountNumber" placeholder="Account number" />
                </div>
            }

            <div class="form-group">
                <label class="form-label">Amount (USD)</label>
                <InputNumber class="form-input" @bind-Value="model.Amount" placeholder="0.00" />
                <ValidationMessage For="@(() => model.Amount)" class="text-danger" />
            </div>

            <div class="form-group">
                <label class="form-label">Memo (Optional)</label>
                <InputText class="form-input" @bind-Value="model.Description" placeholder="e.g., Monthly savings" />
            </div>

            <button type="submit" class="btn btn-primary btn-lg btn-full" style="margin-top: 1rem;" disabled="@isLoading">
                @(isLoading ? "Processing..." : "Transfer Funds")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private TransferRequestDto model = new() { TransactionType = "Internal" };
    private string? successMessage;
    private string? errorMessage;
    private bool isLoading = false;

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;
        
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);
            
            var tokenResult = await SessionStorage.GetAsync<string>("authToken");
            if (tokenResult.Success && !string.IsNullOrEmpty(tokenResult.Value))
            {
                client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", tokenResult.Value);
            }
            else
            {
                errorMessage = "Authentication token missing. Please log in again.";
                return;
            }
            
            var response = await client.PostAsJsonAsync("api/transaction/transfer", model);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<TransferResult>();
                successMessage = result?.Message ?? $"Successfully transferred ${model.Amount:N2}.";
                model = new TransferRequestDto { TransactionType = model.TransactionType, FromAccount = model.FromAccount }; 
            }
            else
            {
                try 
                {
                    var errorResult = await response.Content.ReadFromJsonAsync<ErrorResult>();
                    errorMessage = errorResult?.Message ?? "An error occurred during transfer.";
                } 
                catch 
                {
                    errorMessage = $"Error {response.StatusCode}: Unable to process the transfer.";
                }
            }
        }
        catch (Exception)
        {
            errorMessage = "A network error occurred. Please try again.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private List<bank.Models.Account> myAccounts = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdStr = user.FindFirst("id")?.Value;

        if (!string.IsNullOrEmpty(userIdStr) && Guid.TryParse(userIdStr, out var userId))
        {
            using var scope = ServiceProvider.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<bank.Data.BankDbContext>();
            myAccounts = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.ToListAsync(
                System.Linq.Queryable.Where(dbContext.Accounts, a => a.UserId == userId)
            );

            if (myAccounts.Any() && string.IsNullOrEmpty(model.FromAccount))
            {
                model.FromAccount = myAccounts.First().AccountNumber;
            }
        }
    }

    private string GetRoutingPlaceholder() => model.TransactionType switch
    {
        "RTP" => "e.g. BANKB",
        "FedNow" => "e.g. 010101012",
        _ => "e.g. 010101012"
    };

    private class TransferResult
    {
        public string? Message { get; set; }
        public decimal NewBalance { get; set; }
    }
    
    private class ErrorResult
    {
        public string? Message { get; set; }
    }
}
